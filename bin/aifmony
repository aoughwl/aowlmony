#!/usr/bin/env node
// Deprecated alias — the driver is now `aowlmony`. Forwards argv + exit code.
const r = require("child_process").spawnSync(process.execPath,
  [require("path").join(__dirname, "aowlmony"), ...process.argv.slice(2)],
  { stdio: "inherit" });
process.exit(r.status == null ? 0 : r.status);
