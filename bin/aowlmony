#!/usr/bin/env node
// aowlmony — the nimony rewrite driver over the aoughwl self-owned stack.
//
//   .nim ──► aowlparser (ours) ──► nimony sem + hexer (reused) ──► .s.aif / .c.aif
//                                                                    │        │
//                                              aowli (ours, interpret)┘        └─ aowlc (ours, native C → gcc)
//
// The user's own module(s) are parsed by OUR aowlparser; the standard library is
// parsed by the real nifler (it uses `concept`/typed-nil forms aowlparser does
// not emit yet — a known aowlparser gap). Semantic analysis and hexer's lowering
// (ARC, closures, exceptions, monomorphisation) are reused from nimony until the
// self-owned aowlsem is finished. Code is then either run natively via aowlc or
// interpreted via aowli — the interpreter is a first-class execution mode, and is
// also the intended compile-time / macro engine (replacing nimony's build-and-
// exec native macro plugins).
//
// Commands:
//   aowlmony run    <file.nim>                      native: whole module → binary → run
//   aowlmony build  <file.nim> [-o BIN]             native: emit a binary at BIN
//   aowlmony exec   <file.nim> --entry NAME [--arg V…]   native: call one proc, print result
//   aowlmony interp <file.nim>                      interpret via aowli (first-class)
//   aowlmony vm     <file.nim>                      interpret via aowli's bytecode VM
//   aowlmony ts     <file.nim> [--faithful] [--run] idiomatic TypeScript via aowlts
//   aowlmony py     <file.nim> [--run]              idiomatic Python via aowlpy
//   aowlmony js     <file.nim> [--faithful] [--run] idiomatic JavaScript via aowljs
//   aowlmony parse  <file.nim>                      show OUR aowlparser .p.aif
//   aowlmony nif    <file.nim>                      compile only; print .s.aif / .c.aif paths
//
// Options: -o/--out, --entry, --arg (repeatable), --engine c|aowlc, --faithful,
//   --run, --keep, -v/--verbose
//
// The ts/py/js commands produce the sem'd .s.aif (same artifact as interp) and
// run the matching idiomatic backend (aowlts/aowljs/aowlpy) to emit source next
// to the .nim (or -o); --run also executes it (node / python3). --faithful
// (ts/js) selects int64-exact emission.
//
// Tool locations resolve from env (AOWLMONY_*), then ./aowlmony.config.json, then
// ~/{nimony,aowlparser,aowli,aowlc} defaults. See `resolveTools()`.
"use strict";
const fs = require("fs");
const os = require("os");
const path = require("path");
const cp = require("child_process");

const HOME = os.homedir();

// ---- shared aoughwl CLI style (mirrors ~/.aowl/bin/aowl) --------------------
const COLOR = !process.env.NO_COLOR && process.env.TERM !== "dumb" &&
  (!!process.env.FORCE_COLOR || process.stdout.isTTY);
const rgb = (r, g, b) => (s) => COLOR ? `\x1b[38;2;${r};${g};${b}m${s}\x1b[0m` : String(s);
const sgr = (a, z = 0) => (s) => COLOR ? `\x1b[${a}m${s}\x1b[${z}m` : String(s);
const C = { bold: sgr(1, 22), dim: sgr(2, 22), teal: rgb(45, 212, 191), violet: rgb(167, 139, 250),
  green: rgb(52, 211, 153), amber: rgb(251, 191, 36), red: rgb(248, 113, 113), cyan: rgb(103, 232, 249), gray: rgb(120, 130, 145) };
const G = { diamond: "◆", ok: "✓", cross: "✗", arrow: "→", bar: "│", gear: "⚙", dot: "●" };

function firstExisting(cands) { for (const c of cands) if (c && fs.existsSync(c)) return c; return cands[cands.length - 1]; }
// The ecosystem is rebranding nif* → aif* → aowl* (aowl intermediate format),
// and a sibling session may be mid-rename/rebuild (repo dir and binary can even
// disagree, e.g. ~/aifparser/bin/aowlparser). Resolve every tool from all three
// prefixes (newest first) and from nimcache build dirs so the driver keeps
// working throughout the churn.
function allPrefixes(name) {
  return [name.replace(/^nif/, "aowl"), name.replace(/^nif/, "aif"), name]; // aowl → aif → nif
}
function nifparserCandidates() {
  const out = [path.join(__dirname, "..", "vendor", "nifparser")];
  const names = allPrefixes("nifparser"); // aowlparser, aifparser, nifparser
  for (const repo of names) {
    for (const bin of names) out.push(path.join(HOME, repo, "bin", bin));
    const ncDir = path.join(HOME, repo, "nimcache");
    try { for (const d of fs.readdirSync(ncDir)) {
      for (const bin of names) { const c = path.join(ncDir, d, bin); if (fs.existsSync(c)) out.push(c); }
    } } catch (_) {}
  }
  return out;
}
// Candidate paths for a tool that may live under ~/aowlX / ~/aifX / ~/nifX with a
// binary named the same (optionally suffixed, e.g. aowli-interp / aowli-interp).
function repoBin(base, suffix) {
  const out = [];
  for (const repo of allPrefixes(base))
    for (const bin of allPrefixes(base))
      out.push(path.join(HOME, repo, "bin", bin + (suffix || "")));
  return out;
}

// Consult the aowl registry (~/.aowl) — the single source of truth for the active
// PROFILE + resolved component exes. Falls back to {} so the driver still runs
// standalone (no ~/.aowl) exactly as before.
function loadStack() {
  // the manager (aowlup) owns the registry; resolve its script from the repo or
  // the ~/.aowl data-home shim. AOWL_PROFILE (from `+profile`) flows via env.
  const cands = [path.join(HOME, "aowlup", "bin", "aowlup"), path.join(HOME, ".aowl", "bin", "aowl")];
  const aowl = cands.find((p) => fs.existsSync(p));
  if (!aowl) return {};
  const r = cp.spawnSync(process.execPath, [aowl, "config"],
    { encoding: "utf8", env: Object.assign({}, process.env, { NO_COLOR: "1" }) });
  if (r.status !== 0 || !r.stdout) return {};
  try { return JSON.parse(r.stdout); } catch (_) { return {}; }
}

function resolveTools() {
  let cfg = {};
  for (const _n of ["aowlmony.config.json", "aifmony.config.json"]) {  // latter = deprecated alias
    const _p = path.join(process.cwd(), _n);
    if (fs.existsSync(_p)) { try { cfg = JSON.parse(fs.readFileSync(_p, "utf8")); break; } catch (_) {} }
  }
  const st = loadStack(), slots = st.slots || {};
  const reg = (slot) => (slots[slot] && slots[slot].exe) || "";
  // precedence: AOWLMONY_* env → aowlmony.config.json (or deprecated aifmony.config.json) → aowlup registry → probe.
  const pick = (env, key, def) =>
    process.env[env] || process.env[env.replace(/^AOWLMONY_/, "AIFMONY_")] || cfg[key] || def;
  const t = {
    nimony:    pick("AOWLMONY_NIMONY",    "nimony",    firstExisting([path.join(HOME, "nimony/bin/nimony")])),
    niflerReal:pick("AOWLMONY_NIFLER",    "nifler",    firstExisting([path.join(HOME, "nimony/bin/nifler")])),
    nifparser: pick("AOWLMONY_NIFPARSER", "nifparser", firstExisting(nifparserCandidates())),
    nifiInterp:pick("AOWLMONY_NIFI",      "nifiInterp",reg("interp") || firstExisting(repoBin("nifi", "-interp"))),
    nifiVm:    pick("AOWLMONY_NIFI_VM",   "nifiVm",    reg("vm")     || firstExisting(repoBin("nifi", "-vm"))),
    nifc:      pick("AOWLMONY_NIFC",      "nifc",      reg("native") || firstExisting(repoBin("nifc"))),
    // OUR lowering pass (aowlhexer). Used only when the active profile selects the
    // aowlhexer variant (see below); AOWLMONY_NO_AOWLHEXER=1 forces nimony's hexer.
    aifhexer:  pick("AOWLMONY_HEXER",     "aifhexer",  firstExisting([
                 path.join(HOME, "aowlhexer/bin/aowlhexer"), path.join(HOME, "aifhexer/bin/aifhexer")])),
    // OUR idiomatic-source backends (aowlts/aowljs/aowlpy); registry-resolved,
    // else probed across the aowl/aif/nif prefix family.
    aowlts:    pick("AOWLMONY_AOWLTS",    "aowlts",    reg("ts") || firstExisting(repoBin("nifts"))),
    aowljs:    pick("AOWLMONY_AOWLJS",    "aowljs",    reg("js") || firstExisting(repoBin("nifjs"))),
    aowlpy:    pick("AOWLMONY_AOWLPY",    "aowlpy",    reg("py") || firstExisting(repoBin("nifpy"))),
  };
  // Which stack variant is active for each swappable pass. compile() uses these to
  // decide whether to inject OUR parser/hexer or defer to nimony's nifler/hexer.
  t.profile       = st.profile || "hybrid";
  t.parserVariant = (slots.parser || {}).variant || "aowlparser";
  t.hexerVariant  = (slots.hexer  || {}).variant || "aowlhexer";
  t.semVariant    = (slots.sem    || {}).variant || "nimsem";
  if (t.parserVariant === "aowlparser" && reg("parser")) t.nifparser = process.env.AOWLMONY_NIFPARSER || process.env.AOWLMONY_NIFPARSER || cfg.nifparser || reg("parser");
  if (t.hexerVariant === "aowlhexer" && reg("hexer"))    t.aifhexer  = process.env.AOWLMONY_HEXER || process.env.AOWLMONY_HEXER || cfg.aifhexer  || reg("hexer");
  return t;
}

function fail(msg) { console.error("  " + C.red(G.cross) + " " + C.red(msg)); process.exit(1); }
function log(o, ...a) { if (o.verbose) console.error("  " + C.dim(G.dot) + " " + C.gray(a.join(" "))); }

function parseArgs(argv) {
  const o = { args: [], _: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === "--") { o._.push(...argv.slice(i + 1)); break; }
    else if (a === "-o" || a === "--out") o.out = argv[++i];
    else if (a === "--entry") o.entry = argv[++i];
    else if (a === "--arg") o.args.push(argv[++i]);
    else if (a === "--engine") o.engine = argv[++i];
    else if (a === "--faithful") o.faithful = true;
    else if (a === "--run") o.run = true;
    else if (a === "--keep") o.keep = true;
    else if (a === "-v" || a === "--verbose") o.verbose = true;
    else o._.push(a);
  }
  return o;
}

// The nifler-compatible shim: OUR aowlparser for the user module(s) in
// $NIFRW_USER; the real nifler for the stdlib and the --deps import sidecar.
function shimScript(t) {
  return `#!/usr/bin/env bash
REAL_NIFLER=${JSON.stringify(t.niflerReal)}
NIFPARSER=${JSON.stringify(t.nifparser)}
wants_deps=0; pos=(); infile=""
for a in "$@"; do
  case "$a" in
    --deps) wants_deps=1 ;;
    --portablePaths|-f|--forceRebuild|--deps*) ;;
    p|parse) pos+=("p") ;;
    *.nim) pos+=("$a"); infile="$a" ;;
    *) pos+=("$a") ;;
  esac
done
real_in="$(readlink -f "$infile" 2>/dev/null)"
is_user=0
IFS=':' read -ra USERS <<< "\${NIFRW_USER:-}"
for u in "\${USERS[@]}"; do [ -n "$u" ] && [ "$(readlink -f "$u" 2>/dev/null)" = "$real_in" ] && is_user=1; done
if [ "$is_user" = 1 ]; then
  [ "$wants_deps" = 1 ] && "$REAL_NIFLER" "$@" >/dev/null 2>&1
  exec "$NIFPARSER" "\${pos[@]}"
else
  exec "$REAL_NIFLER" "$@"
fi
`;
}

// Run aowlparser → nimony (sem+hexer) and return { dir, mainHash, snif, cnif, pnif }.
// The staging dir is persistent and keyed by the source path so `nimony c`'s
// incremental cache is reused across invocations (only the first run is cold).
function compile(nimFile, o, t) {
  if (!fs.existsSync(nimFile)) fail("no such file: " + nimFile);
  const abs = path.resolve(nimFile);
  // Key the persistent stage on the source path AND the active stack variants, so
  // switching profile (parser/hexer/sem) never reuses another profile's cached
  // .p/.s/.c artifacts (nimony's incremental cache would otherwise skip re-parsing).
  const key = require("crypto").createHash("sha1")
    .update([abs, t.parserVariant, t.hexerVariant, t.semVariant].join("\0"))
    .digest("hex").slice(0, 12);
  const stage = o.out && o.keep ? path.join(path.dirname(abs), ".aowlmony")
    : path.join(os.tmpdir(), "aowlmony-cache", key);
  fs.mkdirSync(stage, { recursive: true });
  // parser: inject OUR aowlparser (via the nifler shim) only when the active
  // profile selects the aowlparser variant; otherwise let nimony's own nifler
  // parse everything (the `nimony` profile / `aowl use parser nifler`).
  const useOurParser = (t.parserVariant || "aowlparser") === "aowlparser";
  const shim = path.join(stage, "nifler");
  if (useOurParser) { fs.writeFileSync(shim, shimScript(t)); fs.chmodSync(shim, 0o755); }
  else if (fs.existsSync(shim)) fs.rmSync(shim);
  // Stage a `hexer` shim → aowlhexer so nimony's build (findTool("hexer")) uses
  // OUR lowering pass — only when the profile selects the aowlhexer variant.
  // AOWLMONY_NO_AOWLHEXER=1 forces nimony's hexer regardless.
  const wantAifhexer = (t.hexerVariant || "aowlhexer") === "aowlhexer";
  const useAifhexer = wantAifhexer && t.aifhexer && fs.existsSync(t.aifhexer) && !(process.env.AOWLMONY_NO_AOWLHEXER || process.env.AOWLMONY_NO_AOWLHEXER);
  const hexerShim = path.join(stage, "hexer");
  if (useAifhexer) {
    fs.writeFileSync(hexerShim, "#!/usr/bin/env bash\nexec " + JSON.stringify(t.aifhexer) + " \"$@\"\n");
    fs.chmodSync(hexerShim, 0o755);
  } else if (fs.existsSync(hexerShim)) {
    fs.rmSync(hexerShim);   // ensure a stale shim doesn't linger in the cache
  }
  o._usedAifhexer = useAifhexer;
  const nc = path.join(stage, "nc");

  const env = Object.assign({}, process.env, {
    NIFRW_USER: abs,
    PATH: stage + path.delimiter + process.env.PATH,
  });
  log(o, "nifparser parses", path.basename(abs) + "; sem via nimony;",
    useAifhexer ? "lowering via aowlhexer (ours)" : "lowering via nimony hexer");
  const r = cp.spawnSync(t.nimony, ["c", "--nimcache:" + nc, abs],
    { cwd: stage, env, encoding: "utf8" });
  if (o.verbose && r.stderr) process.stderr.write(r.stderr);

  // main module: the nc subdir that holds <hash>.c.aif matching its own name
  let mainHash = null, cnif = null;
  if (fs.existsSync(nc)) {
    for (const d of fs.readdirSync(nc)) {
      const sub = path.join(nc, d);
      if (fs.statSync(sub).isDirectory()) {
        const c = path.join(sub, d + ".c.nif");
        if (fs.existsSync(c)) { mainHash = d; cnif = c; break; }
      }
    }
  }
  if (!mainHash) {
    if (r.status !== 0) { process.stderr.write(r.stderr || r.stdout || ""); fail("nimony frontend failed"); }
    fail("could not locate the compiled main module (.c.nif) in " + nc);
  }
  const snif = path.join(nc, mainHash + ".s.nif");
  const pnif = path.join(nc, mainHash + ".p.nif");
  // provenance check: the user module must have been parsed by OUR aowlparser
  let byOurParser = false;
  try { byOurParser = /vendor "(?:nif|aif|aowl)parser"/.test(fs.readFileSync(pnif, "utf8")); } catch (_) {}
  return { stage, nc, mainHash, snif, cnif, pnif, byOurParser };
}

function runTool(bin, args, opts = {}) {
  return cp.spawnSync(bin, args, Object.assign({ stdio: "inherit" }, opts));
}

// Idiomatic-source backends (aowlts/aowljs/aowlpy). Each reads the main
// module's sem'd .s.aif (imported user modules are pulled from the same nc dir
// by the backend itself) and writes emitted source to stdout; we capture it and
// write `outFile`. `--faithful` (ts/js only) selects int64-exact emission.
function emitBackend(bin, snif, outFile, faithful, lang, o, t) {
  if (!bin || !fs.existsSync(bin)) fail(lang + " backend not found (set AOWLMONY_AOWL" +
    lang.toUpperCase() + " or build ~/aowl" + lang + "/bin/aowl" + lang + ")");
  const args = [];
  if (faithful) args.push("--faithful");
  args.push(snif);
  log(o, lang, "backend", path.basename(bin), "emits", path.basename(outFile),
    faithful ? "(faithful)" : "");
  const r = cp.spawnSync(bin, args, { encoding: "utf8" });
  if (r.status !== 0) { process.stderr.write(r.stderr || ""); fail(lang + " backend failed"); }
  fs.writeFileSync(outFile, r.stdout);
  return outFile;
}

// Where to put the emitted source: -o if given, else beside the .nim source.
function outPath(nimFile, o, ext) {
  if (o.out) return path.resolve(o.out);
  const abs = path.resolve(nimFile);
  return path.join(path.dirname(abs), path.basename(abs, path.extname(abs)) + "." + ext);
}

function main() {
  const argv = process.argv.slice(2);
  // `+profile` (rustup-style) = compile with an ephemeral toolchain profile for
  // this one invocation; flows to `aowl config` via AOWL_PROFILE (see loadStack).
  if (argv[0] && argv[0][0] === "+") process.env.AOWL_PROFILE = argv.shift().slice(1);
  const cmd = argv[0];
  const o = parseArgs(argv.slice(1));
  const t = resolveTools();

  if (!cmd || cmd === "-h" || cmd === "--help" || cmd === "help") {
    process.stdout.write("\n  " + C.teal(G.diamond) + " " + C.bold(C.teal("aowlmony")) + "  " +
      C.dim(G.bar) + "  " + C.gray("nimony driver over the self-owned aowl stack") + "\n\n");
    const rows = [
      ["run FILE", "native: compile → binary → run"],
      ["build FILE [-o BIN]", "native: emit a binary"],
      ["exec FILE --entry N", "native: call one proc, print result"],
      ["interp FILE", "interpret via aowli (tree-walk)"],
      ["vm FILE", "interpret via aowli bytecode VM"],
      ["ts|js FILE [--faithful]", "emit idiomatic TypeScript / JavaScript"],
      ["py FILE", "emit idiomatic Python"],
      ["parse FILE", "show OUR .p.nif"],
      ["nif FILE", "compile only; print .s/.c.nif paths"],
    ];
    for (const [a, d] of rows) console.log("  " + C.teal(a) + " ".repeat(Math.max(1, 26 - a.length)) + C.gray(d));
    console.log("");
    console.log("  " + C.gray("profile ") + G.arrow + " " + C.bold(C.violet(t.profile)) +
      C.dim("  parser=") + C.cyan(t.parserVariant) + C.dim(" hexer=") + C.cyan(t.hexerVariant) +
      C.dim(" sem=") + C.cyan(t.semVariant) + C.dim("   one-shot: ") + C.teal("aowlmony +nimony run <file>"));
    console.log("  " + C.gray("options ") + G.arrow + " " +
      C.dim("-o  --entry  --arg  --engine  --faithful  --run  --keep  -v"));
    console.log("  " + C.gray("toolchain ") + G.arrow + " " + C.teal("aowlup") +
      C.dim("   — aowlup manages the stack (profiles/versions/setup), aowlmony compiles (rustup : cargo)"));
    console.log("");
    return;
  }

  if (t.semVariant === "aowlsem")
    console.error("  " + C.amber("!") + " " + C.gray("profile selects ") + C.cyan("sem=aowlsem") +
      C.gray(" — not yet wired into the driver; using nimony sem for this build"));

  if (cmd === "parse") {
    const f = o._[0]; if (!f) fail("parse needs a .nim file");
    const r = runTool(t.nifparser, ["p", f, "-"]);   // '-' output → stdout
    process.exit(r.status || 0);
  }

  const file = o._[0];
  if (!file) fail(cmd + " needs a .nim file");
  const b = compile(file, o, t);
  if (o.verbose) log(o, "main module", b.mainHash, "parsed by",
    b.byOurParser ? "nifparser (ours)" : "nifler (fallback)");

  switch (cmd) {
    case "nif":
      console.log(".p.nif  " + b.pnif + (b.byOurParser ? "  (nifparser)" : "  (nifler)"));
      console.log(".s.nif  " + b.snif);
      console.log(".c.nif  " + b.cnif);
      break;
    case "interp": {
      const r = runTool(t.nifiInterp, [b.snif]);
      process.exit(r.status == null ? 0 : r.status);
    }
    case "vm": {
      const r = runTool(t.nifiVm, [b.snif]);
      process.exit(r.status == null ? 0 : r.status);
    }
    case "exec": {
      if (!o.entry) fail("exec needs --entry NAME");
      const a = ["exec", b.cnif, "--entry", o.entry];
      for (const v of o.args) a.push("--arg", v);
      const r = runTool("node", [t.nifc, ...a]);
      process.exit(r.status == null ? 0 : r.status);
    }
    case "build": {
      const a = ["build", b.cnif];
      if (o.out) a.push("-o", o.out);
      const r = runTool("node", [t.nifc, ...a]);
      process.exit(r.status == null ? 0 : r.status);
    }
    case "run": {
      const a = ["run", b.cnif];
      const r = runTool("node", [t.nifc, ...a]);
      process.exit(r.status == null ? 0 : r.status);
    }
    case "ts": {
      const out = emitBackend(t.aowlts, b.snif, outPath(file, o, "ts"), o.faithful, "ts", o, t);
      console.error("  " + C.green(G.ok) + " " + C.gray("wrote ") + C.cyan(out.replace(HOME, "~")));
      if (o.run) {
        const r = runTool("node", ["--experimental-transform-types", "--no-warnings", out]);
        process.exit(r.status == null ? 0 : r.status);
      }
      break;
    }
    case "py": {
      const out = emitBackend(t.aowlpy, b.snif, outPath(file, o, "py"), false, "py", o, t);
      console.error("  " + C.green(G.ok) + " " + C.gray("wrote ") + C.cyan(out.replace(HOME, "~")));
      if (o.run) {
        const r = runTool("python3", [out]);
        process.exit(r.status == null ? 0 : r.status);
      }
      break;
    }
    case "js": {
      const out = emitBackend(t.aowljs, b.snif, outPath(file, o, "js"), o.faithful, "js", o, t);
      console.error("  " + C.green(G.ok) + " " + C.gray("wrote ") + C.cyan(out.replace(HOME, "~")));
      if (o.run) {
        // aowljs's flush emits a top-level `return __out;`; wrap the module in an
        // IIFE and print its return value (same as aowljs's own run harness).
        const src = fs.readFileSync(out, "utf8");
        const r = runTool("node", ["-e", "process.stdout.write((function(){" + src + "})())"]);
        process.exit(r.status == null ? 0 : r.status);
      }
      break;
    }
    default:
      fail("unknown command '" + cmd + "'. Try `aowlmony help`.");
  }
}

try { main(); } catch (e) { fail((e && e.stack) || String(e)); }
